# Auth mode: local | github | hybrid
AUTH_MODE=local

# GitHub OAuth (required for github/hybrid auth mode)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub repo for DB snapshots (org/repo format)
GITHUB_REPO=

# GitHub personal access token for DB commits
GITHUB_TOKEN=

# Database path
DB_PATH=data/sampletown.db

# Origin URL — must exactly match the public URL the browser uses.
# Required for SvelteKit CSRF protection AND for setting Secure on the
# session cookie (Secure is set when ORIGIN starts with https://).
ORIGIN=http://localhost:5173

# One-time bootstrap token for creating the first admin user.
# Set to a random hex string before first deploy. Submit it as the
# `setup_token` form field on /auth/login when creating the initial admin.
# Unset (or leave blank) after the first admin exists.
ADMIN_SETUP_TOKEN=
