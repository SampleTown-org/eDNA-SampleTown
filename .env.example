# Auth mode: local | github | hybrid
AUTH_MODE=local

# GitHub OAuth (required for github/hybrid auth mode)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub repo for DB snapshots (org/repo format)
GITHUB_REPO=

# GitHub personal access token for DB commits
GITHUB_TOKEN=

# Database path
DB_PATH=data/sampletown.db

# Origin URL — must exactly match the public URL the browser uses.
# Required for SvelteKit CSRF protection AND for setting Secure on the
# session cookie (Secure is set when ORIGIN starts with https://).
ORIGIN=http://localhost:5173

# Max request body in bytes. SvelteKit's adapter-node defaults to 512 KB,
# fine for JSON but far too small for the photo-upload feature (phone JPEGs
# run 1-5 MB). Bump to at least 15 MB if you use photos.
BODY_SIZE_LIMIT=20000000

# SvelteKit adapter-node client-IP source. When running behind a reverse
# proxy (nginx / caddy), the socket peer address is 127.0.0.1 for every
# request, which collapses the IP-keyed rate limiter to a single global
# bucket. Setting ADDRESS_HEADER=X-Forwarded-For + XFF_DEPTH=1 tells the
# adapter to read the last entry from the X-Forwarded-For chain — nginx
# with `proxy_set_header X-Forwarded-For $remote_addr;` populates it with
# the true client IP. If the app is exposed directly (no proxy), leave
# these unset — trusting a header an attacker can forge is worse than
# useless.
# ADDRESS_HEADER=X-Forwarded-For
# XFF_DEPTH=1

# Default lab name for the first-run seed. The first-ever boot creates a
# single lab with this name and assigns the seeded admin user + any
# migrated pre-multi-lab data to it. Subsequent labs are created via
# scripts/create-lab.mjs — there is no UI for lab creation.
DEFAULT_LAB_NAME=Cryomics Lab

# NOTE: SampleTown seeds a default `admin/admin` account on first startup
# (if the users table is empty). The first login forces a password change
# before anything else can be done. Bootstrap from a private network or
# SSH tunnel BEFORE exposing the app on the public internet.
