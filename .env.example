# Auth mode: local | github | hybrid
AUTH_MODE=local

# GitHub OAuth (required for github/hybrid auth mode)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub repo for DB snapshots (org/repo format)
GITHUB_REPO=

# GitHub personal access token for DB commits
GITHUB_TOKEN=

# Database path
DB_PATH=data/sampletown.db

# Origin URL (required for CSRF protection)
ORIGIN=http://localhost:5173

# Session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=
