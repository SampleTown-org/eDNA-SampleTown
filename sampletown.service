[Unit]
Description=SampleTown eDNA Database
After=network.target

[Service]
Type=simple
User=grid
WorkingDirectory=/data/sampletown
ExecStart=/usr/bin/node build/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOST=0.0.0.0
EnvironmentFile=/data/sampletown/.env

[Install]
WantedBy=multi-user.target
